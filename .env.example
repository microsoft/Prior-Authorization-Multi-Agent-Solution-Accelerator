# =============================================================================
# Prior Authorization Review — Root Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env (in this root directory) and fill in your values:
#   cp .env.example .env
#
# docker-compose.yml substitutes these variables into all FOUR agent containers
# (clinical, coverage, compliance, synthesis). The FastAPI backend reads its
# own env vars from backend/.env (see backend/.env.example).
#
# The .env file is gitignored and will NOT be committed.
# =============================================================================

# ---------------------------------------------------------------------------
# Azure AI Foundry — project endpoint (REQUIRED by all 4 agent containers)
# ---------------------------------------------------------------------------
# Get this from: Azure AI Foundry portal → your project → Home tab
# Format: https://<resource-name>.services.ai.azure.com
AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-resource-name>.services.ai.azure.com

# ---------------------------------------------------------------------------
# Model deployment name (REQUIRED by all 4 agent containers)
# ---------------------------------------------------------------------------
# The Azure OpenAI deployment name from:
# Azure AI Foundry → Build tab → Deployments → deployment name
# Common values: gpt-4o, gpt-4o-mini
# Note: compliance agent defaults to gpt-4o-mini; others default to gpt-4o
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ---------------------------------------------------------------------------
# MCP Server URLs (optional — production defaults are pre-set in docker-compose.yml)
# ---------------------------------------------------------------------------
# Override only if you want to point at local or custom MCP server instances.
# All DeepSense URLs require User-Agent: claude-code/1.0 — injected automatically.

# MCP_ICD10_CODES=https://mcp.deepsense.ai/icd10_codes/mcp
# MCP_PUBMED=https://pubmed.mcp.claude.com/mcp
# MCP_CLINICAL_TRIALS=https://mcp.deepsense.ai/clinical_trials/mcp
# MCP_NPI_REGISTRY=https://mcp.deepsense.ai/npi_registry/mcp
# MCP_CMS_COVERAGE=https://mcp.deepsense.ai/cms_coverage/mcp

# ---------------------------------------------------------------------------
# Azure Application Insights (optional — shared by all containers)
# ---------------------------------------------------------------------------
# APPLICATION_INSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
