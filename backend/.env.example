# =============================================================================
# Prior Authorization Review — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is for LOCAL DEVELOPMENT and DOCKER COMPOSE only.
# For Azure deployment (azd up), credentials are set via:
#   azd env set AZURE_FOUNDRY_API_KEY <value>
#   azd env set AZURE_FOUNDRY_ENDPOINT <value>
#
# The .env file is gitignored and will NOT be committed.
# =============================================================================

# ---------------------------------------------------------------------------
# Microsoft Foundry — Claude model endpoint (REQUIRED)
# ---------------------------------------------------------------------------
# Get these from Microsoft Foundry portal (ai.azure.com) > your project:
#   - Home tab > "Project API key" → AZURE_FOUNDRY_API_KEY
#   - Home tab > "Project endpoint" + "/anthropic" → AZURE_FOUNDRY_ENDPOINT
#   - Build tab > Deployments > deployment name → CLAUDE_MODEL
#
# See: https://learn.microsoft.com/en-us/azure/foundry/foundry-models/how-to/use-foundry-models-claude
AZURE_FOUNDRY_API_KEY=your-azure-foundry-api-key-here
AZURE_FOUNDRY_ENDPOINT=https://<your-foundry-resource-name>.services.ai.azure.com/anthropic
CLAUDE_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Agent Configuration
# ---------------------------------------------------------------------------
# Skills-based approach (default: true)
# true  = agents use SKILL.md files via MAF native skill discovery
# false = agents use inline system prompt instructions (prompt-based)
USE_SKILLS=true

# ---------------------------------------------------------------------------
# Frontend CORS origin (optional)
# ---------------------------------------------------------------------------
# For local dev with Next.js dev server (npm run dev):
FRONTEND_ORIGIN=http://localhost:3000
# For Docker Compose, this is set automatically in docker-compose.yml.
# For Azure deployment, this is set automatically by Bicep.

# ---------------------------------------------------------------------------
# Azure Application Insights (optional — enables OpenTelemetry tracing)
# ---------------------------------------------------------------------------
# Get from Azure Portal → Application Insights → Overview → Connection String
# For Azure deployment (azd up), this is set automatically by Bicep.
# APPLICATION_INSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...;LiveEndpoint=...

# ---------------------------------------------------------------------------
# Healthcare MCP Server endpoints (optional — defaults shown below)
# ---------------------------------------------------------------------------
# These are the Anthropic Healthcare MCP Marketplace servers.
# The defaults point to the production DeepSense and Anthropic-hosted
# endpoints. Override only if you're running local MCP server instances.
#
# IMPORTANT: All DeepSense MCP servers require the header
# "User-Agent: claude-code/1.0" — this is configured automatically
# in backend/app/tools/mcp_config.py.

# NPI Registry — provider verification (CMS NPPES)
# MCP_NPI_REGISTRY=https://mcp.deepsense.ai/npi_registry/mcp

# ICD-10 Codes — diagnosis code validation (2026 code set)
# MCP_ICD10_CODES=https://mcp.deepsense.ai/icd10_codes/mcp

# CMS Coverage — Medicare LCDs/NCDs policy lookup
# MCP_CMS_COVERAGE=https://mcp.deepsense.ai/cms_coverage/mcp

# PubMed — biomedical literature search
# MCP_PUBMED=https://pubmed.mcp.claude.com/mcp

# Clinical Trials — ClinicalTrials.gov search
# MCP_CLINICAL_TRIALS=https://mcp.deepsense.ai/clinical_trials/mcp
